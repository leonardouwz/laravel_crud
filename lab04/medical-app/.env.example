APP_NAME="Medical App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8100
LOG_CHANNEL=stack
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=medical_db
